generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum PromoType {
  FIXED
  PERCENTAGE
  CLIENT
  WHOLESALE
}

model Product {
  id          Int         @id @default(autoincrement())
  brand       String
  name        String
  nameAr      String?
  description String
  descriptionAr String?
  price       Float
  oldPrice    Float?
  promoPrice  Float?
  wholesalePrice Float?
  bulkWholesalePrice Float?
  image       String
  categories  Category[]
  collections Collection[]
  badge       String?
  isVisible   Boolean     @default(true)
  isArchived  Boolean     @default(false)
  isEssential Boolean     @default(false)
  isPromo     Boolean     @default(false)
  isNew       Boolean     @default(false)
  salesCount  Int         @default(0)
  stock       Int         @default(0)
  tags        String[]
  concerns    String[]
  koreanBeautyStep Int?      // 1-10 pour les étapes Korean Beauty
  supplementFocus String?    // Focus Compléments Alimentaires: sleep, stress, digest, metabolic, immunity, beauty
  makeupStep  Int?           // 1-11 pour les étapes Maquillage
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  searchVector Unsupported("tsvector")?

  @@index([isVisible])
  @@index([isEssential])
  @@index([createdAt])
  @@index([koreanBeautyStep])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  nameAr      String
  slug        String    @unique
  description String?
  image       String?
  page        String    @default("general")
  order       Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([page])
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  page        String    // e.g. "korean-beauty", "complements", "maquillage"
  order       Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([page])
}

model Order {
  id             String         @id @default(cuid())
  orderNumber    String         @unique
  customerName   String
  phone          String
  city           String
  address        String
  items          OrderItem[]
  total          Float
  status         OrderStatus    @default(PENDING)
  deliveryStatus DeliveryStatus @default(PENDING)
  syncedToSheets Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  name      String
  quantity  Int
  price     Float
  image     String
}

model Promo {
  id          String    @id @default(cuid())
  code        String    @unique
  type        PromoType
  value       Float
  expiresAt   DateTime
  usageLimit  Int?
  usageCount  Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SectionConfig {
  id          String   @id @default(cuid())
  sectionKey  String   @unique // e.g., 'essentials', 'best_sellers'
  bannerImage String
  updatedAt   DateTime @updatedAt
}

model Banner {
  id          String   @id @default(cuid())
  section     String   @unique // e.g., 'korean_beauty_hero', 'makeup_promo'
  title       String?
  imageUrl    String
  linkUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OfficialShop {
  id       Int    @id @default(autoincrement())
  category String // 'kbeauty', 'complements', 'maquillage'
  name     String
  order    Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, name])
  @@index([category])
}
