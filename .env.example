# ==========================================
# FASSIA SECRET — Environment Variables
# ==========================================

# ─── Database ─────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/fassia_secret?schema=public"

# ─── Admin Authentication ─────────────────
ADMIN_SECRET="your-admin-secret"
JWT_SECRET="your-jwt-secret-very-long-and-random"

# ─── Redis (Optional) ────────────────────
# If not set, backend falls back to in-memory cache
# REDIS_URL="redis://localhost:6379"

# ─── URLs ────────────────────────────────
FRONTEND_URL="https://fassiasecret.com"
NEXT_PUBLIC_API_URL="https://fassiasecret.com/api"

# ─── Backend Port ────────────────────────
PORT=5000
