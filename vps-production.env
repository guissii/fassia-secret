# ==========================================
# FASSIA SECRET — VPS PRODUCTION (.env)
# ==========================================
# Copier ce fichier sur le VPS: /var/www/fassia-secret/.env
# IMPORTANT: Changez TOUS les mots de passe avant de déployer !

# ─── PostgreSQL ───────────────────────────────────
POSTGRES_USER=fassia_admin
POSTGRES_PASSWORD=CHANGEZ_MOI_MotDePasse_SuperSecure_2026!
POSTGRES_DB=fassia_secret_prod

# ─── Prisma / Backend Database URL ────────────────
# localhost car PostgreSQL tourne sur le même VPS
DATABASE_URL="postgresql://fassia_admin:CHANGEZ_MOI_MotDePasse_SuperSecure_2026!@localhost:5432/fassia_secret_prod?schema=public"

# ─── Authentification Admin ──────────────────────
ADMIN_SECRET="CHANGEZ_MOI_secret_admin_2026"
JWT_SECRET="CHANGEZ_MOI_jwt_secret_tres_long_et_aleatoire_2026"

# ─── Redis ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── URLs Production ─────────────────────────────
# Remplacez par votre vrai domaine
FRONTEND_URL="https://fassia-secret.com"
NEXT_PUBLIC_API_URL="https://fassia-secret.com/api"
NEXT_PUBLIC_SITE_URL="https://fassia-secret.com"

# ─── Ports internes ──────────────────────────────
PORT=5000
