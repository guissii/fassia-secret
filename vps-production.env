# ==========================================
# VARIABLES D'ENVIRONNEMENT POUR LE VPS (PRODUCTION)
# ==========================================

# 1. Base de données (PostgreSQL)
# Identifiants de la base de données (ces valeurs seront utilisées par docker-compose)
POSTGRES_USER=fassia_admin
POSTGRES_PASSWORD=MotDePasseSuperSecurise123!
POSTGRES_DB=fassia_secret_prod

# L'URL de connexion complète utilisée par Prisma et le Backend
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Ici, le HOST est "db" car c'est le nom du service dans docker-compose.yml
DATABASE_URL="postgresql://fassia_admin:MotDePasseSuperSecurise123!@db:5432/fassia_secret_prod?schema=public"

# 2. Authentification & Sécurité (Backend)
# Clé secrète pour signer les tokens JWT (Générez une longue chaîne aléatoire)
JWT_SECRET="g9b2a7c4f1d8e3x0q5z6w8m9v2n4b7l0k1j3h5g8f4d2s1a7"

# Clé secrète pour l'accès administrateur (si vous l'utilisez)
ADMIN_SECRET="secret_admin_fassia_2026_xyz"

# 3. URLs du projet
# Remplacez "votre-domaine.com" par votre vrai nom de domaine une fois acheté.
# L'URL sur laquelle le frontend tournera (pour configurer les CORS du backend)
FRONTEND_URL="https://fassia-secret.com"

# L'URL de l'API pour le frontend Next.js (doit pointer vers votre backend)
NEXT_PUBLIC_API_URL="https://api.fassia-secret.com/api"

# Le port sur lequel le backend Express tournera en interne (laissez 5000)
PORT=5000
